# ═══════════════════════════════════════════════════════════════════
# Lumo Learn — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# For local development (filled automatically by `supabase start`):
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=<printed by supabase start>

# ── Edge Function secrets (set via supabase secrets, not here) ──────
# These are stored in Supabase Vault, not in this file.
# To set: supabase secrets set OPENAI_API_KEY=sk-...
# OPENAI_API_KEY=  ← NEVER put this here

# ── RevenueCat ──────────────────────────────────────────────────────
REVENUECAT_API_KEY_IOS=appl_xxxxxxxxxxxx
REVENUECAT_API_KEY_ANDROID=goog_xxxxxxxxxxxx

# ── Firebase (Push Notifications) ───────────────────────────────────
# Download google-services.json and GoogleService-Info.plist
# from Firebase Console and place them in:
#   android/app/google-services.json
#   ios/Runner/GoogleService-Info.plist

# ── App Config ──────────────────────────────────────────────────────
APP_ENV=development   # development | staging | production
